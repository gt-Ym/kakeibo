rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ─────────────────────────────────────────
    // グローバル設定（認証済みユーザーが読み書き可能）
    // itemSortOrder: 項目の並び順をここに保存
    // ─────────────────────────────────────────
    match /settings/{docId} {
      allow read, write: if request.auth != null;
    }

    // ─────────────────────────────────────────
    // グローバル項目（全認証ユーザーが読み取り可能、書き込みは管理者のみ）
    // ─────────────────────────────────────────
    match /items/{itemId} {
      allow read:  if request.auth != null;
      allow write: if request.auth != null &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.userName == "admin";
    }

    // ─────────────────────────────────────────
    // ユーザープロファイル（認証済みユーザーが閲覧可能、書き込みは本人のみ）
    // ※ admin がユーザー一覧を取得するために全ユーザーが読み取り可能
    // ─────────────────────────────────────────
    match /users/{userId} {
      allow read:  if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // ─────────────────────────────────────────
    // メソッド（認証済みユーザーが読み取り可能、書き込みは本人または管理者のみ）
    // ※ コレクションクエリ（list）で get() が機能しないため読み取りは全認証ユーザーに許可
    // ─────────────────────────────────────────
    match /users/{userId}/methods/{methodId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && (
        request.auth.uid == userId ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.userName == "admin"
      );
    }

    // ─────────────────────────────────────────
    // ユーザーデータのサブコレクション（本人または管理者が読み書き可能）
    // ─────────────────────────────────────────
    match /users/{userId}/{document=**} {
      allow read, write: if request.auth != null && (
        request.auth.uid == userId ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.userName == "admin"
      );
    }

    // ─────────────────────────────────────────
    // グループ共有取引の閲覧（同グループメンバーが読み取り可能）
    // ─────────────────────────────────────────
    match /users/{userId}/transactions/{txId} {
      allow read: if request.auth != null && (
        request.auth.uid == userId ||
        (
          resource.data.isGroupShared == true &&
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.groupId == resource.data.groupId
        ) ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.userName == "admin"
      );
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // ─────────────────────────────────────────
    // グループ共有メソッド（同グループメンバーが読み書き可能）
    // ─────────────────────────────────────────
    match /groups/{groupId}/{document=**} {
      allow read, write: if request.auth != null &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.groupId == groupId;
    }
  }
}
