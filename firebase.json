{
  "hosting": {
    "public": ".",
    "ignore": [
      "firebase.json",
      ".firebaserc",
      "firestore.rules",
      "functions/**",
      "GAS/**",
      "*.xlsx",
      "ToDo",
      "めも.xlsx",
      "SETUP.md",
      "node_modules/**"
    ],
    "redirects": [
      {
        "source": "/",
        "destination": "/html/login.html",
        "type": 302
      }
    ],
    "headers": [
      {
        "source": "**/*.@(html|js|css)",
        "headers": [
          { "key": "Cache-Control", "value": "no-cache" }
        ]
      }
    ]
  },
  "firestore": {
    "rules":   "firestore.rules",
    "indexes": "firestore.indexes.json"
  }
}
